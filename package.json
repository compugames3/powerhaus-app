{
    "name": "gimnasio",
    "version": "2.9.17",
    "description": "",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "test": "echo \"Error: no test specified\" && exit 1",
        "build": "electron-builder"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "dependencies": {
        "cors": "^2.8.6",
        "electron-updater": "^6.8.9",
        "express": "^5.2.1",
        "googleapis": "^173.0.0",
        "pg": "^8.20.0"
    },
    "build": {
        "appId": "com.powerhaus.app",
        "productName": "PowerHaus",
        "asar": false,
        "files": [
            "**/*",
            "!dist/**",
            "!node_modules/.cache/**"
        ],
        "win": {
            "icon": "build/icon.png",
            "target": [
                "nsis",
                "portable"
            ]
        },
        "mac": {
            "icon": "build/icon.png",
            "target": [
                "dmg",
                "zip"
            ]
        },
        "linux": {
            "icon": "build/icon.png",
            "target": [
                "AppImage",
                "deb"
            ]
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": "always"
        },
        "publish": [
            {
                "provider": "github",
                "owner": "compugames3",
                "repo": "powerhaus-app"
            }
        ]
    },
    "devDependencies": {
        "electron": "^41.2.0",
        "electron-builder": "^26.8.1",
        "eslint": "^10.2.1",
        "javascript-obfuscator": "^5.4.1"
    }
}